    alias: "BotCoder254"
repository-code: "https://github.com/BotCoder254/limboo"
url: "https://github.com/BotCoder254/limboo"
license: MIT
version: "1.0.0"
keywords:
  - electron
  - ai
  - coding-agent
  - local-first
  - developer-tools
  - typescript
  - react
